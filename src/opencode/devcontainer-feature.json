{
  "name": "OpenCode CLI",
  "id": "opencode",
  "version": "1.0.3",
  "description": "Install OpenCode - an AI-powered development tool for software engineering tasks",
  "options": {
    "version": {
      "type": "string",
      "default": "latest",
      "description": "OpenCode version to install (e.g. 'latest', '1.0.180', or 'v1.0.180')"
    }
  },
  "mounts": [
    {
      "source": "opencode-data",
      "target": "/usr/local/share/opencode-data",
      "type": "volume"
    }
  ],
  "containerEnv": {
    "XDG_DATA_HOME": "/usr/local/share/opencode-data/data",
    "XDG_CONFIG_HOME": "/usr/local/share/opencode-data/config",
    "XDG_CACHE_HOME": "/usr/local/share/opencode-data/cache",
    "XDG_STATE_HOME": "/usr/local/share/opencode-data/state"
  },
  "installsAfter": [
    "ghcr.io/devcontainers/features/common-utils"
  ]
}
