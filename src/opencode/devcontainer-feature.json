{
  "name": "OpenCode CLI",
  "id": "opencode",
  "version": "1.0.10",
  "description": "Install OpenCode - an AI-powered development tool for software engineering tasks",
  "options": {
    "version": {
      "type": "string",
      "default": "latest",
      "description": "OpenCode version to install (e.g. 'latest', '1.0.180', or 'v1.0.180')"
    },
    "opencode-base": {
      "type": "string",
      "description": "Base directory for opencode persistent data (data/config/cache/state). Required for data persistence."
    }
  },
  "mounts": [
    {
      "source": "opencode-data",
      "target": "/usr/local/share/opencode-data",
      "type": "volume"
    }
  ],
  "installsAfter": [
    "ghcr.io/devcontainers/features/common-utils"
  ],
  "postCreateCommand": "bash /usr/local/share/opencode-feature/postCreate.sh"
}
